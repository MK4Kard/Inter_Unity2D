  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ca338b65cc462d34fa77a700e19a62d4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TypewriterWithDOTween
  textCanvas: {fileID: 500788328}
  textComponent: {fileID: 632225569}
  fullText: "<b>\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C,
    \u0441\u0442\u0430\u0436\u0435\u0440!</b>\\n\\n\u0417\u0434\u0435\u0441\u044C
    \u0432\u0430\u0441 \u0436\u0434\u0443\u0442 \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0438\u0435
    \u043A\u0432\u0435\u0441\u0442\u044B, \u0437\u0430\u0433\u0430\u0434\u043A\u0438
    \u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u0442\u044C\u0441\u044F
    \u0432 \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0443 \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430.\\n\\n\u041F\u0440\u0438\u0433\u043E\u0442\u043E\u0432\u044C\u0442\u0435\u0441\u044C
    \u043A \u043D\u0435\u0437\u0430\u0431\u044B\u0432\u0430\u0435\u043C\u044B\u043C
    \u043F\u0440\u0438\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F\u043C \u0438
    \u043D\u0435 \u0437\u0430\u0431\u044B\u0432\u0430\u0439\u0442\u0435 \u0437\u0430\u0434\u0430\u0432\u0430\u0442\u044C
    \u0432\u043E\u043F\u0440\u043E\u0441\u044B - \u0432\u0435\u0434\u044C \u0438\u043C\u0435\u043D\u043D\u043E
    \u0442\u0430\u043A \u0432\u044B \u043E\u0442\u043A\u0440\u043E\u0435\u0442\u0435
    \u0434\u043B\u044F \u0441\u0435\u0431\u044F \u0432\u0441\u0435 \u0442\u0430\u0439\u043D\u044B
    \u044D\u0442\u043E\u0433\u043E \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430!"
  typeDuration: 5
  delayBeforeShow: 2
  autoClose: 0
  waitForSpace: 1
  onTypingComplete:
